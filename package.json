{
  "name": "@crediscore/tokens",
  "version": "1.0.0",
  "description": "Modular design tokens compilation system with multi-framework support",
  "author": {
    "name": "Crediscore Team UXUI"
  },
  "main": "../../config/dist/index.js",
  "types": "../../config/dist/index.d.ts",
  "type": "commonjs",
  "exports": {
    ".": {
      "import": "./../../config/dist/index.js",
      "types": "./../../config/dist/index.d.ts"
    },
    "./cli": {
      "import": "./../../config/dist/cli/index.js",
      "types": "./../../config/dist/cli/index.d.ts"
    },
    "./builders": {
      "import": "./../../config/dist/builders/index.js",
      "types": "./../../config/dist/builders/index.d.ts"
    },
    "./types": {
      "import": "./../../config/dist/types/index.js",
      "types": "./../../config/dist/types/index.d.ts"
    },
    "./utils": {
      "import": "./../../config/dist/utils/index.js",
      "types": "./../../config/dist/utils/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "../../config/dist/**/*",
    "src/**/*",
    "theme.tokens.json"
  ],
  "scripts": {
    "build": "tsx src/cli/index.ts build",
    "build:legacy": "node build.ts --build",
    "watch": "tsx src/cli/index.ts watch",
    "validate": "tsx src/cli/index.ts validate",
    "clean": "tsx src/cli/index.ts clean",
    "dev": "tsx src/cli/index.ts build --watch",
    "type-check": "tsc --noEmit",
    "compile": "tsc",
    "prepublishOnly": "npm run compile",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "prepublish": "npm run test && npm run compile"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^11.1.0",
    "inquirer": "^13.3.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.0.0",
    "typescript": "^5.9.2"
  },
  "bin": {
    "design-tokens": "./../../config/dist/src/cli/index.js"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}