{
    "global": {
        "color": {
            "primary": "#4585C6",
            "secondary": "#86BD45",
            "neutral": "#2D2D2C",
            "azulHorizonte": "#4585C6",
            "azulHorizonteAlt": "#5A9FD4",
            "azulHorizonteDark": "#3468A0",
            "azulHorizonteLight": "#6BB6FF",
            "verdeVitalidad": "#86BD45",
            "verdeVitalidadHover": "#9BC85D",
            "rojoAlerta": "#D32F2F",
            "naranjaAdvertencia": "#F57C00",
            "verdeExito": "#388E3C",
            "azulInfo": "#1976D2",
            "grisTexto": "#707070",
            "verdeExitoClaro": "#3CB179",
            "verdeExitoOscuro": "#30A46C",
            "rojoErrorClaro": "#F2555A",
            "rojoErrorOscuro": "#E5484D",
            "amarilloAdvertenciaClaro": "#FFEF5C",
            "amarilloAdvertenciaOscuro": "#F5D90A",
            "azulHorizonteClaro": "#6BA3D9",
            "azulHorizonteOscuro": "#3468A0",
            "verdeVitalidadClaro": "#A5D470",
            "verdeVitalidadOscuro": "#86BD45",
            "white": "#FFFFFF",
            "black": "#000000"
        },
        "space": {
            "xs": 4,
            "sm": 8,
            "md": 16,
            "lg": 24,
            "xl": 32
        },
        "typography": {
            "fontFamily": {
                "montserrat": "Montserrat, sans-serif",
                "jetbrains": "JetBrains Mono, monospace"
            },
            "fontSize": {
                "body": 16,
                "heading": 24,
                "caption": 12
            },
            "fontWeight": {
                "normal": 400,
                "medium": 500,
                "semibold": 600,
                "bold": 700
            },
            "lineHeight": {
                "tight": 1.25,
                "normal": 1.5,
                "relaxed": 1.75
            }
        },
        "radius": {
            "sm": 4,
            "md": 8,
            "lg": 12,
            "xl": 16
        },
        "opacity": {
            "transparent": 0,
            "semi": 0.5,
            "opaque": 1
        },
        "zIndex": {
            "base": 0,
            "overlay": 1000,
            "modal": 2000
        },
        "borderWidth": {
            "none": 0,
            "thin": 1,
            "thick": 2
        },
        "size": {
            "icon": 24,
            "avatar": 40,
            "thumbnail": 80
        },
        "motion": {
            "fast": "150ms",
            "normal": "300ms",
            "slow": "500ms"
        },
        "screens": {
            "sm": "640px",
            "md": "768px",
            "lg": "1024px",
            "xl": "1280px"
        }
    },
    "light": {
        "theme": {
            "background": "#FFFFFF",
            "text": "#000000"
        }
    },
    "dark": {
        "theme": {
            "background": "#000000",
            "text": "#FFFFFF"
        }
    },
    "$themes": ["light", "dark"]
}
